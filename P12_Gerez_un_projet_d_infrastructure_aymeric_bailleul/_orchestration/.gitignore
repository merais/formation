# .gitignore – _orchestration/

# Secrets et configuration locale
.env

# Cache Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Artefacts dbt (generes lors de l'execution)
dbt/sport_data/target/
dbt/sport_data/dbt_packages/
dbt/sport_data/logs/

# Logs pipeline
logs/
*.log

# Donnees sources (XLSX) – ne pas versionner les donnees brutes
data/

# Artefacts Kestra (si montes localement)
kestra/

# IDE
.vscode/
.idea/

# Windows
desktop.ini
Thumbs.db
