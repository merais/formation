# ──────────────────────────────────────────────────────────────────────────────
# _orchestration/.env.example
# Copier ce fichier en .env et adapter les valeurs.
# Ce fichier N'est PAS commite (voir .gitignore).
# ──────────────────────────────────────────────────────────────────────────────

# ─── PostgreSQL (partage entre sport_data et kestra) ─────────────────────────
POSTGRES_HOST=localhost
POSTGRES_DB=sport_data
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# Port expose sur l'hote (interne Docker = 5432)
POSTGRES_PORT=5433

# ─── Chemins absolus vers les dossiers sources ────────────────────────────────
# Dossier contenant les fichiers XLSX (Données+RH.xlsx, Données+Sportive.xlsx)
# Utiliser des slashes (/) meme sur Windows pour Docker Desktop.
XLSX_DIR=G:/Mon Drive/_formation_over_git/P12_Gerez_un_projet_d_infrastructure_aymeric_bailleul/_projet/data/RAW


# ─── Kestra ──────────────────────────────────────────────────────────────────
KESTRA_PORT=8080
KESTRA_EMAIL=votre@email.com
KESTRA_PASSWORD=votre_mot_de_passe

# ─── Slack ───────────────────────────────────────────────────────────────────
# URL du webhook Incoming Slack encodee en base64
# Obtenir l'URL sur https://api.slack.com/apps puis encoder :
#   [Convert]::ToBase64String([Text.Encoding]::UTF8.GetBytes("https://hooks.slack.com/..."))
SLACK_WEBHOOK_B64=
