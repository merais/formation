# ──────────────────────────────────────────────────────────────────────────────
# _orchestration/.env.example
# Copier ce fichier en .env et adapter les valeurs.
# Ce fichier N'est PAS commite (voir .gitignore).
# ──────────────────────────────────────────────────────────────────────────────

# ─── PostgreSQL (partage entre sport_data et kestra) ─────────────────────────
POSTGRES_HOST=localhost
POSTGRES_DB=sport_data
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# Version base64 du mot de passe (pour les secrets Kestra)
# [Convert]::ToBase64String([Text.Encoding]::UTF8.GetBytes("votre_mot_de_passe"))
POSTGRES_PASSWORD_B64=cG9zdGdyZXM=
# Port expose sur l'hote (interne Docker = 5432)
POSTGRES_PORT=5433

# ─── Chemins absolus vers les dossiers sources ────────────────────────────────
# Dossier contenant les fichiers XLSX (Données+RH.xlsx, Données+Sportive.xlsx)
# Inclus dans _orchestration/data/RAW — adapter si les fichiers sont ailleurs.
# Utiliser des slashes (/) meme sur Windows pour Docker Desktop.
XLSX_DIR=G:/Mon Drive/_formation_over_git/P12_Gerez_un_projet_d_infrastructure_aymeric_bailleul/_orchestration/data/RAW


# ─── Kestra ──────────────────────────────────────────────────────────────────
KESTRA_PORT=8080
KESTRA_EMAIL=votre@email.com
KESTRA_PASSWORD=votre_mot_de_passe

# ─── Google Maps API ────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=
# Version base64 de la cle API (pour les secrets Kestra)
# [Convert]::ToBase64String([Text.Encoding]::UTF8.GetBytes("votre_cle_api"))
GOOGLE_MAPS_API_KEY_B64=
ENTREPRISE_ADRESSE=1362 Av. des Platanes, 34970 Lattes

# ─── Slack ───────────────────────────────────────────────────────────────────
# Webhooks Incoming Slack encodes en base64
# Obtenir l'URL sur https://api.slack.com/apps puis encoder :
#   [Convert]::ToBase64String([Text.Encoding]::UTF8.GetBytes("https://hooks.slack.com/..."))
#
# Webhook 1 : messages aleatoires par activite Strava
SLACK_WEBHOOK_B64=
# Webhook 2 : compte-rendu d'execution du pipeline (succes / echec)
SLACK_WEBHOOK_INFO_B64=
