# Variables d'environnement – P12 Sport Data Solution
# Copier ce fichier en .env et renseigner les valeurs

# PostgreSQL (Docker)
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=sport_data
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Roles PostgreSQL (crees par init_db.py --reset)
# Choisir des mots de passe forts en production
DB_USER_PIPELINE=role_pipeline
DB_PASS_PIPELINE=
DB_USER_ANALYTICS=role_analytics
DB_PASS_ANALYTICS=
DB_USER_RH=role_rh_admin
DB_PASS_RH=

# Google Maps API
# Obtenir une clé sur https://console.cloud.google.com
# Activer : Distance Matrix API
GOOGLE_MAPS_API_KEY=

# Adresse de l'entreprise (référence pour le calcul des distances)
ENTREPRISE_ADRESSE=1362 Av. des Platanes, 34970 Lattes
