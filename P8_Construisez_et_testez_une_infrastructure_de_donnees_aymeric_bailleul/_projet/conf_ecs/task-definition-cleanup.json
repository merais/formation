{
  "family": "s3-cleanup",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::343374742393:role/WeatherPipelineECSTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::343374742393:role/WeatherPipelineECSTaskRole",
  "containerDefinitions": [
    {
      "name": "s3-cleanup",
      "image": "343374742393.dkr.ecr.eu-west-1.amazonaws.com/weather-etl:latest",
      "essential": true,
      "command": ["python", "ABAI_P8_script_04_cleanup_s3.py"],
      "environment": [
        {
          "name": "WATCH_INTERVAL",
          "value": "3600"
        },
        {
          "name": "MONGODB_HOST",
          "value": "mongodb.weather-pipeline.local"
        },
        {
          "name": "MONGODB_PORT",
          "value": "27017"
        },
        {
          "name": "MONGODB_DATABASE",
          "value": "weather_data"
        },
        {
          "name": "MONGODB_COLLECTION",
          "value": "measurements"
        }
      ],
      "secrets": [
        {
          "name": "AWS_ACCESS_KEY_ID",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:343374742393:secret:weather-pipeline/aws-credentials-2KPEIG:AWS_ACCESS_KEY_ID::"
        },
        {
          "name": "AWS_SECRET_ACCESS_KEY",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:343374742393:secret:weather-pipeline/aws-credentials-2KPEIG:AWS_SECRET_ACCESS_KEY::"
        },
        {
          "name": "AWS_DEFAULT_REGION",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:343374742393:secret:weather-pipeline/aws-credentials-2KPEIG:AWS_DEFAULT_REGION::"
        },
        {
          "name": "S3_BUCKET_NAME",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:343374742393:secret:weather-pipeline/s3-config-rORPK7:S3_BUCKET_NAME::"
        },
        {
          "name": "MONGODB_ROOT_USER",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:343374742393:secret:weather-pipeline/mongodb-credentials-4mUhUe:MONGODB_ROOT_USER::"
        },
        {
          "name": "MONGODB_ROOT_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:343374742393:secret:weather-pipeline/mongodb-credentials-4mUhUe:MONGODB_ROOT_PASSWORD::"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/weather-s3-cleanup",
          "awslogs-region": "eu-west-1",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}
