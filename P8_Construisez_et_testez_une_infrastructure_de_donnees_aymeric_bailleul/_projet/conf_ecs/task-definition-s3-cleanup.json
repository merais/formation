{
  "family": "weather-s3-cleanup",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/WeatherPipelineECSTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/WeatherPipelineECSTaskRole",
  "containerDefinitions": [
    {
      "name": "s3-cleanup",
      "image": "ACCOUNT_ID.dkr.ecr.REGION.amazonaws.com/weather-etl:latest",
      "essential": true,
      "command": ["python", "ABAI_P8_script_04_cleanup_s3.py", "--watch"],
      "environment": [
        {
          "name": "AWS_REGION",
          "value": "REGION"
        },
        {
          "name": "MONGODB_DATABASE",
          "value": "weather_data"
        },
        {
          "name": "MONGODB_COLLECTION",
          "value": "measurements"
        },
        {
          "name": "MONGODB_URI",
          "value": "mongodb://MONGODB_USER:MONGODB_PASSWORD@mongodb.weather-pipeline.local:27017/"
        },
        {
          "name": "CLEANUP_INTERVAL",
          "value": "3600"
        }
      ],
      "secrets": [
        {
          "name": "AWS_ACCESS_KEY_ID",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:weather-pipeline/aws-credentials:AWS_ACCESS_KEY_ID::"
        },
        {
          "name": "AWS_SECRET_ACCESS_KEY",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:weather-pipeline/aws-credentials:AWS_SECRET_ACCESS_KEY::"
        },
        {
          "name": "S3_BUCKET_NAME",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:weather-pipeline/s3-config:S3_BUCKET_NAME::"
        },
        {
          "name": "S3_PREFIX_SOURCE",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:weather-pipeline/s3-config:S3_PREFIX_SOURCE::"
        },
        {
          "name": "S3_PREFIX_DESTINATION",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:weather-pipeline/s3-config:S3_PREFIX_DESTINATION::"
        },
        {
          "name": "S3_PREFIX_ARCHIVE",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:weather-pipeline/s3-config:S3_PREFIX_ARCHIVE::"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/weather-s3-cleanup",
          "awslogs-region": "REGION",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}
