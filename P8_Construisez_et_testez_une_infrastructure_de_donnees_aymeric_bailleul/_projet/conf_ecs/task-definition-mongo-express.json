{
  "family": "weather-mongo-express",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/WeatherPipelineECSTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/WeatherPipelineECSTaskRole",
  "containerDefinitions": [
    {
      "name": "mongo-express",
      "image": "mongo-express:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8081,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "ME_CONFIG_MONGODB_URL",
          "value": "mongodb://MONGODB_USER:MONGODB_PASSWORD@mongodb.weather-pipeline.local:27017/"
        }
      ],
      "secrets": [
        {
          "name": "ME_CONFIG_MONGODB_ADMINUSERNAME",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:weather-pipeline/mongodb-credentials:MONGODB_ROOT_USER::"
        },
        {
          "name": "ME_CONFIG_MONGODB_ADMINPASSWORD",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:weather-pipeline/mongodb-credentials:MONGODB_ROOT_PASSWORD::"
        },
        {
          "name": "ME_CONFIG_BASICAUTH_USERNAME",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:weather-pipeline/mongo-express-credentials:MONGO_EXPRESS_USER::"
        },
        {
          "name": "ME_CONFIG_BASICAUTH_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:weather-pipeline/mongo-express-credentials:MONGO_EXPRESS_PASSWORD::"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/weather-mongo-express",
          "awslogs-region": "REGION",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}
