{
  "family": "weather-etl",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::343374742393:role/WeatherPipelineECSTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::343374742393:role/WeatherPipelineECSTaskRole",
  "containerDefinitions": [
    {
      "name": "etl-pipeline",
      "image": "343374742393.dkr.ecr.eu-west-1.amazonaws.com/weather-etl:latest",
      "essential": true,
      "command": ["python", "ABAI_P8_script_01_clean_data.py"],
      "environment": [
        {
          "name": "AWS_REGION",
          "value": "eu-west-1"
        },
        {
          "name": "MONGODB_DATABASE",
          "value": "weather_data"
        },
        {
          "name": "MONGODB_COLLECTION",
          "value": "measurements"
        },
        {
          "name": "MONGODB_URI",
          "value": "mongodb://MONGODB_USER:MONGODB_PASSWORD@mongodb.weather-pipeline.local:27017/"
        },
        {
          "name": "WATCH_INTERVAL",
          "value": "3600"
        }
      ],
      "secrets": [
        {
          "name": "AWS_ACCESS_KEY_ID",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:343374742393:secret:weather-pipeline/aws-credentials-2KPEIG:AWS_ACCESS_KEY_ID::"
        },
        {
          "name": "AWS_SECRET_ACCESS_KEY",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:343374742393:secret:weather-pipeline/aws-credentials-2KPEIG:AWS_SECRET_ACCESS_KEY::"
        },
        {
          "name": "S3_BUCKET_NAME",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:343374742393:secret:weather-pipeline/s3-config-rORPK7:S3_BUCKET_NAME::"
        },
        {
          "name": "S3_PREFIX_SOURCE",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:343374742393:secret:weather-pipeline/s3-config-rORPK7:S3_PREFIX_SOURCE::"
        },
        {
          "name": "S3_PREFIX_DESTINATION",
          "valueFrom": "arn:aws:secretsmanager:eu-west-1:343374742393:secret:weather-pipeline/s3-config-rORPK7:S3_PREFIX_DESTINATION::"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/weather-etl",
          "awslogs-region": "eu-west-1",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}
