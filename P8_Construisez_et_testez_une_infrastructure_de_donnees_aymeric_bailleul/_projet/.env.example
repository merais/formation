# Configuration AWS S3 (EXEMPLE)
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=eu-west-1
S3_BUCKET_NAME=p8-weather-data
S3_PREFIX_SOURCE=01_raw/
S3_PREFIX_DESTINATION=02_cleaned/
S3_PREFIX_ARCHIVE=03_archived/

# Configuration MongoDB
MONGODB_ROOT_USER=admin
MONGODB_ROOT_PASSWORD=admin123
MONGODB_DATABASE=weather_data
MONGODB_COLLECTION=measurements

# Configuration Mongo Express (Interface Web MongoDB)
# Credentials pour accéder à http://localhost:8081
MONGO_EXPRESS_USER=admin
MONGO_EXPRESS_PASSWORD=pass

# Configuration du service d'import automatique
# Intervalle de vérification en secondes (300 = 5 minutes)
WATCH_INTERVAL=300

# Configuration du service de nettoyage S3
# Intervalle de nettoyage en secondes (3600 = 1 heure)
CLEANUP_INTERVAL=3600
